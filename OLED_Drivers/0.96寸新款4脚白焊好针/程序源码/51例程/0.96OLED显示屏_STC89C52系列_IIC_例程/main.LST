   1          //  功能描述   : OLED 4接口演示例程(51系列)
   2          //            说明: 显示屏插在插座上的时候，一定要注意GND,VCC对应好；不要插错了；否则容易损坏
   3          //               程序运行以后开发板上的D6 LED灯闪烁，此时显示屏会有画面不停的刷新
   4          //              ----------------------------------------------------------------
   5          //              GND    电源地
   6          //              VCC  接5V或3.3v电源
   7          //              SCL=   P1^4（SCL）
   8          //              SDA   P1^3（SDA）
   9          
  10          #include "REG51.h"
  11          #include "oled.h"
  12          #include "bmp.h"
  13          
  14           int main(void)
  15           { u8 t;
  16   1               OLED_Init();         //初始化OLED  
  17   1            OLED_Clear()   ; 
  18   1         
  19   1            t=' ';
  20   1            OLED_ShowString(6,3,"0.96' OLED TEST",16); 
  21   1          //   OLED_ShowString(20,4,"2014/05/01");  
  22   1            OLED_ShowString(0,6,"ASCII:",16);  
  23   1            OLED_ShowString(63,6,"CODE:",16); 
  24   1      OLED_ShowChar(48,6,t,16);//显示ASCII字符        
  25   1         while(1) 
  26   1         {     
  27   2      
  28   2               
  29   2            t++;
  30   2            if(t>'~')t=' ';
  31   2         LED6=0; //发光二极管
  32   2            OLED_ShowNum(103,6,t,3,16);//显示ASCII字符的码值   
  33   2               delay_ms(20);
  34   2               LED6=1;
  35   2               delay_ms(20);
  36   2      
  37   2         }    
  38   1         
  39   1      }
